EXPO_PUBLIC_API_URL=http://localhost:8000

# RevenueCat SDK public keys (from Project settings → API keys). Injected at build time.
# Local dev / simulator: iOS "Test store" or public test key (test_…) is OK.
# TestFlight & App Store: use the Apple App Store public key (appl_…), not test_.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
# Play Store release: Google Play public key (goog_…)
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=
