EXPO_PUBLIC_API_URL=http://localhost:8000

# Pro bypass (team): UUIDs/emails/phones, comma-separated. Also set FITFO_PRO_BYPASS_* on the API.
# EXPO_PUBLIC_BILLING_BYPASS_USER_IDS=
# EXPO_PUBLIC_BILLING_BYPASS_EMAILS=
# EXPO_PUBLIC_BILLING_BYPASS_PHONES=

# Set to 1 to skip the 7-day in-app trial and show the paywall unless user is Pro or bypassed.
# EXPO_PUBLIC_FORCE_PAYWALL=1

# EAS project ID (expo.dev → Project settings) for Expo push tokens. Optional in Expo Go.
# EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RevenueCat SDK public keys (from Project settings → API keys). Injected at build time.
# Local dev / simulator: iOS "Test store" or public test key (test_…) is OK.
# TestFlight & App Store: use the Apple App Store public key (appl_…), not test_.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
# Play Store release: Google Play public key (goog_…)
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=
