API_HOST=0.0.0.0
API_PORT=8000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

GROQ_API_KEY=your-groq-key
ENABLE_FRAME_OCR=1
FRAME_OCR_PROVIDER_PRIORITY=groq,openai
FRAME_OCR_GROQ_MODEL=
OPENAI_API_KEY=your-openai-key
FRAME_OCR_OPENAI_MODEL=gpt-4o-mini

APIFY_TOKEN=your-apify-token

APPLE_APP_BUNDLE_ID=com.fitfo.mobile

# ─── Apple Sign In refresh-token revocation (App Store 5.1.1(v)) ─────────────
# Required for DELETE /auth/me to revoke Sign-in-with-Apple refresh tokens.
# Without these, account deletion still works locally but Apple won't be told
# to unlink the app from the user's Apple ID.
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_SIGNIN_KEY_ID=XXXXXXXXXX
# APPLE_SIGNIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SERVICE_SID=your-twilio-verify-service-sid
TWILIO_VERIFY_FRIENDLY_NAME=FitFo

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_EXPIRES_IN_SECONDS=2592000

# ─── Apple App Review demo account ──────────────────────────────────────────
# When set, any /auth/send-otp and /auth/verify-otp request from this phone
# skips Twilio and uses REVIEWER_OTP_CODE directly. Put these credentials in
# App Store Connect → App Information → App Review Information → Demo Account.
# Leave empty in dev / production-facing environments so no one can bypass SMS.
# REVIEWER_PHONE=+15555551234
# REVIEWER_OTP_CODE=424242
